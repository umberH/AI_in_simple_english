# Copy this to .env and fill in your keys
# .env is gitignored — never commit real keys

# Medium Integration Token
# Get from: https://medium.com/me/settings → Integration tokens
MEDIUM_TOKEN=your_medium_integration_token_here

# Notion API Token (for standalone scripts — separate from Claude MCP)
# Get from: https://www.notion.so/my-integrations → Create integration
NOTION_TOKEN=your_notion_token_here

# GitHub settings (for push_post.py)
GITHUB_REPO=your-username/ai-in-simple-english
GITHUB_BRANCH=main

# Personal site repo path (local clone of your GitHub Pages repo)
SITE_REPO_PATH=C:\Users\dumb_\Documents\your-site-repo
